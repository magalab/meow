# Auto detect text files and normalize line endings to LF
* text=auto

# Swift files
*.swift text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.plist text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.icns binary
*.icSet binary
*.app binary
*.dmg binary
*.o binary
*.a binary
*.so binary
